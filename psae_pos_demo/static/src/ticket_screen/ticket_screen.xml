<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name='psae_pos_demo.TicketScreen' t-inherit='point_of_sale.TicketScreen' t-inherit-mode='extension'>
        <xpath expr="//div[hasclass('header-row')]" position='inside'>
            <div class="col end p-2">Order Type</div>
        </xpath>

        <xpath expr="//div[hasclass('order-row')]" position="inside">
            <div class='order-type'><t t-esc="order.orderTypeId || 'None'"></t></div>
        </xpath>
    </t>
</templates>
